{
  "name": "my-tiptap-editor",
  "version": "0.1.0",
  "description": "Beautiful Tiptap 3 + Vue 3 rich-text editor theme with AI support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "build:types": "vue-tsc --project tsconfig.build.json --emitDeclarationOnly",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "format": "prettier --write .",
    "analyze": "ANALYZE=true vite build",
    "release": "pnpm build && pnpm publish"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/vue-3": "^3.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "ant-design-vue": {
      "optional": true
    },
    "@ant-design/icons-vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@tiptap/core": "^3.7.2",
    "@tiptap/extension-bubble-menu": "^3.7.2",
    "@tiptap/extension-character-count": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.7.1",
    "@tiptap/extension-color": "^3.0.0",
    "@tiptap/extension-font-family": "^3.7.2",
    "@tiptap/extension-highlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/extension-subscript": "^3.7.2",
    "@tiptap/extension-superscript": "^3.7.2",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-table-cell": "^3.13.0",
    "@tiptap/extension-table-header": "^3.13.0",
    "@tiptap/extension-table-row": "^3.13.0",
    "@tiptap/extension-task-item": "^3.7.1",
    "@tiptap/extension-task-list": "^3.7.1",
    "@tiptap/extension-text-align": "^3.0.0",
    "@tiptap/extension-text-style": "^3.0.0",
    "@tiptap/extension-typography": "^3.7.2",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/extensions": "^3.11.1",
    "@tiptap/pm": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "@tiptap/vue-3": "^3.7.2",
    "@types/file-saver": "^2.0.7",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "ant-design-vue": "^4.2.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.4.0",
    "lowlight": "^3.3.0",
    "lucide-vue-next": "^0.507.0",
    "prettier": "^3.8.1",
    "rollup-plugin-obfuscator": "^1.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.96.0",
    "terser": "^5.44.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10",
    "vue-types": "^3.0.2"
  },
  "optionalDependencies": {
    "@tiptap/extension-collaboration": "^3.13.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27"
  },
  "keywords": [
    "tiptap",
    "tiptap3",
    "tiptap-editor",
    "tiptap-vue",
    "tiptap-template",
    "tiptap-theme",
    "vue3",
    "vue",
    "vue-component",
    "vue-editor",
    "rich-text-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "editor",
    "theme",
    "ui-kit",
    "ai",
    "ai-editor",
    "ai-writing",
    "collaboration",
    "real-time-collaboration",
    "markdown",
    "prosemirror",
    "contenteditable",
    "text-editor",
    "word-processor",
    "notion",
    "notion-editor",
    "document-editor",
    "typescript",
    "dark-mode",
    "i18n",
    "cms"
  ],
  "author": "Bùi Hữu Thắng",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@tiptap/y-tiptap": "^3.0.2",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "katex": "^0.16.28",
    "mammoth": "^1.11.0"
  }
}
